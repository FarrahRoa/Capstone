APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# If the React SPA is served from a different origin than the API, set this to the SPA base URL.
# Used for links in emails (e.g. reservation email confirmation).
FRONTEND_URL=http://localhost

# Civil time for reservations and availability (Philippines).
APP_TIMEZONE=Asia/Manila

# Cloud / fallback sync (admin-only UI at /admin/cloud-sync). On the temporary fallback server, set to local_fallback
# so new reservations are queued for upload when the primary returns.
APP_SYNC_RECORD_ORIGIN=primary
# CLOUD_SYNC_PUSH_URL=https://primary.example.com/api/internal/reservations/sync
# CLOUD_SYNC_PUSH_TOKEN=
# CLOUD_SYNC_REACHABILITY_URL=https://primary.example.com/up
# CLOUD_SYNC_AUTO_ENABLED=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# CORS (only needed if SPA and API are on different origins)
# Comma-separated list of allowed origins, e.g. "https://app.example.com,https://admin.example.com"
CORS_ALLOWED_ORIGINS=
# Keep false for Bearer-token auth. Set true only if you switch to cookie-based SPA auth.
CORS_SUPPORTS_CREDENTIALS=false

# Same-browser OTP skip: HttpOnly cookie (same app origin as /api). Cross-origin SPAs need CORS_SUPPORTS_CREDENTIALS=true and allowed origins.
TRUSTED_DEVICE_COOKIE=xu_trusted_device
TRUSTED_DEVICE_LIFETIME_DAYS=30

# Sanctum (cookie-based SPA auth only; current app uses Bearer tokens)
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000,::1

# Bearer-token session behavior (cloud deployment defaults)
# Absolute expiration (minutes since token creation). Leave blank to disable absolute expiry.
# SANCTUM_EXPIRATION=10080
# Server-side inactivity timeout (minutes since last token use). Set 0 to disable.
SANCTUM_IDLE_TIMEOUT_MINUTES=20160
SANCTUM_ADMIN_IDLE_TIMEOUT_MINUTES=480

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
