<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <staticContent>
      <!-- Ensure correct MIME types for common assets (IIS defaults vary). -->
      <remove fileExtension=".js" />
      <mimeMap fileExtension=".js" mimeType="text/javascript" />
      <remove fileExtension=".css" />
      <mimeMap fileExtension=".css" mimeType="text/css" />
      <remove fileExtension=".map" />
      <mimeMap fileExtension=".map" mimeType="application/json" />
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <remove fileExtension=".svg" />
      <mimeMap fileExtension=".svg" mimeType="image/svg+xml" />
      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
    </staticContent>

    <httpProtocol>
      <customHeaders>
        <!-- Default: don't force cache for HTML. Hashed Vite assets are handled below. -->
      </customHeaders>
    </httpProtocol>

    <rewrite>
      <outboundRules>
        <!-- Cache Vite-built hashed assets aggressively (matches /build/assets/app-<hash>.js etc). -->
        <rule name="Cache Vite hashed assets" preCondition="IsViteBuildAsset">
          <match serverVariable="RESPONSE_Cache-Control" pattern=".*" />
          <action type="Rewrite" value="public, max-age=31536000, immutable" />
        </rule>
      </outboundRules>
      <preConditions>
        <preCondition name="IsViteBuildAsset">
          <!-- Prefer caching only fingerprinted filenames; Vite hashes can include '-' / '_' -->
          <!-- Support /build/assets/* (Laravel default) and /assets/* (some deployments). -->
          <add input="{REQUEST_URI}" pattern="^/(?:build/)?assets/.+-[A-Za-z0-9_-]{8,}\.(?:(?:js|css)(?:\.map)?|woff2?|ttf|eot|svg|png|jpe?g|gif|webp)$" />
        </preCondition>
      </preConditions>
    </rewrite>
  </system.webServer>
</configuration>

